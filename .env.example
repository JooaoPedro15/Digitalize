# Digitalize - exemplo de variaveis de ambiente
# Copie este arquivo para .env localmente e preencha com seus valores.
# Nunca versione o arquivo .env real.

# Servidor Java/Spark
PORT=8080

# PostgreSQL
DB_URL=jdbc:postgresql://localhost:5432/digitalize
DB_USER=postgres
DB_PASS=

# Usuario administrador inicial opcional
# Se estes campos ficarem vazios, a migracao nao cria admin automaticamente.
DIGITALIZE_ADMIN_EMAIL=
DIGITALIZE_ADMIN_PASSWORD=

# Azure OpenAI opcional, usado pelo Guia de Postagem
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=
AZURE_OPENAI_CHAT_DEPLOYMENT=
AZURE_OPENAI_API_VERSION=2024-10-21
